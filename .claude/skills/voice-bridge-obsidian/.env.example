# Voice Bridge Obsidian — Environment Variables
# Copy to .env and fill in values

# Obsidian vault path (required)
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# STT Configuration
STT_ADAPTER=faster_whisper          # faster_whisper | whisper | custom
STT_MODEL=large-v3                  # Model size: tiny, base, small, medium, large-v3
STT_DEVICE=cpu                      # cpu | cuda
STT_COMPUTE_TYPE=int8               # int8 | float16 | float32

# Claude API (optional, for enhanced intent classification)
# CLAUDE_API_KEY=sk-ant-...

# Logging
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs

# Safe mode: when true, ALL actions are record-only
SAFE_MODE=false

# Bridge service settings (optional, for reply support)
# TELEGRAM_BOT_TOKEN=
# WHATSAPP_API_URL=
